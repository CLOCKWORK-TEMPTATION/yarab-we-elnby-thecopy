# ============================================
# Root .env.example — the-copy-monorepo
# Copy this file to .env and fill in the values
# Each app (apps/web, apps/backend) loads from
# its own .env — copy relevant sections there too.
# ============================================

# ─── Runtime ─────────────────────────────────
NODE_ENV=development
# PORT for backend API server
PORT=3001

# ─── Database (PostgreSQL / Neon) ────────────
# Production: use Neon pooler URL with sslmode=require
# Development: can use local PostgreSQL or sqlite fallback
DATABASE_URL=postgresql://user:password@localhost:5432/the_copy
# DATABASE_URL=sqlite://./dev.db

# ─── Redis — Cache + Job Queues ──────────────
# Full connection URL (takes precedence over HOST/PORT/PASSWORD)
REDIS_URL=redis://localhost:6379
# Or configure individually:
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# Toggle Redis features on/off
REDIS_ENABLED=true

# Redis Sentinel (high-availability, optional)
REDIS_SENTINEL_ENABLED=false
# REDIS_SENTINELS=127.0.0.1:26379,127.0.0.1:26380,127.0.0.1:26381
# REDIS_MASTER_NAME=mymaster
# REDIS_SENTINEL_PASSWORD=

# ─── Authentication ──────────────────────────
# MUST be at least 32 characters in production
# MUST NOT contain 'dev-secret' or 'CHANGE-THIS' in production
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# ─── CORS ────────────────────────────────────
# Comma-separated origins allowed by the backend
CORS_ORIGIN=http://localhost:5000,http://localhost:9002
FRONTEND_URL=http://localhost:5000

# ─── Rate Limiting ───────────────────────────
# Window in milliseconds (default: 900000 = 15 min)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ─── AI Providers — API Keys ────────────────
# Google Gemini (primary AI provider for the platform)
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_GENAI_API_KEY=your-gemini-api-key
# Environment-specific Gemini keys (apps/web server-side)
# GEMINI_API_KEY_PROD=
# GEMINI_API_KEY_STAGING=

# Anthropic (used when AGENT_REVIEW_MODEL or FINAL_REVIEW_MODEL is anthropic:*)
# ANTHROPIC_API_KEY=

# OpenAI (used when review models are openai:*)
# OPENAI_API_KEY=

# DeepSeek (used when review models are deepseek:*)
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Mistral (PDF OCR extraction)
# MISTRAL_API_KEY=

# OpenRouter (alternative LLM gateway)
# OPENROUTER_API_KEY=

# Groq (PDF vision judge model)
# GROQ_API_KEY=
# GROQ_ENDPOINT=https://api.groq.com/openai/v1/chat/completions

# Moonshot
# MOONSHOT_API_KEY=

# Alibaba Cloud / DashScope (Qwen vision models)
# DASHSCOPE_API_KEY=
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# QWEN3_ENDPOINT=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ─── AI Models — Editor Review Layer ────────
# Format: provider:model (e.g. anthropic:claude-sonnet-4-6, google-genai:gemini-2.5-flash)
AGENT_REVIEW_MODEL=anthropic:claude-sonnet-4-6
# AGENT_REVIEW_FALLBACK_MODEL=openai:gpt-5-mini
FINAL_REVIEW_MODEL=anthropic:claude-sonnet-4-6
# FINAL_REVIEW_FALLBACK_MODEL=google-genai:gemini-2.5-flash
AI_DOUBT_ENABLED=false

# ─── Tiptap Pro ──────────────────────────────
# Required to install @tiptap-pro packages (referenced in .npmrc)
# Get your token from https://cloud.tiptap.dev/
TIPTAP_PRO_TOKEN=your-tiptap-pro-token

# ─── Sentry — Error Tracking ────────────────
# Server-side DSN
# SENTRY_DSN=
# Build-time config (source maps upload)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
# SENTRY_RELEASE=the-copy@1.0.0
# SENTRY_SERVER_NAME=backend-prod-01
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# ─── NEXT_PUBLIC — Client-Side Variables ─────
# (apps/web only — exposed to the browser bundle)
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_FILE_IMPORT_BACKEND_URL=http://127.0.0.1:8787/api/file-extract
NEXT_PUBLIC_FINAL_REVIEW_BACKEND_URL=http://127.0.0.1:8787/api/final-review
NEXT_PUBLIC_AI_DOUBT_ENABLED=false

# CDN (optional)
NEXT_PUBLIC_ENABLE_CDN=false
# NEXT_PUBLIC_CDN_URL=https://cdn.your-domain.com

# Sentry (browser-side)
# NEXT_PUBLIC_SENTRY_DSN=

# Gemini client-side key (if needed for browser API calls)
# NEXT_PUBLIC_GEMINI_API_KEY=
# NEXT_PUBLIC_GEMINI_MODEL=gemini-2.0-flash-exp

# ─── NEXT_PUBLIC — OpenTelemetry (browser) ───
NEXT_PUBLIC_TRACING_ENABLED=false
# NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT=
NEXT_PUBLIC_SERVICE_NAME=thecopy-frontend
NEXT_PUBLIC_APP_VERSION=1.0.0

# ─── NEXT_PUBLIC — Firebase Auth ─────────────
# Get these from Firebase Console > Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── OpenTelemetry — Backend Tracing ─────────
TRACING_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
SERVICE_NAME=thecopy-backend
# OTEL_LOG_LEVEL=info

# ─── File Import Server (editor sub-server) ──
FILE_IMPORT_HOST=127.0.0.1
FILE_IMPORT_PORT=8787

# ─── Antiword & Poppler (doc/pdf tools) ──────
# Windows: C:/antiword/antiword.exe
# Linux/macOS: antiword (if on PATH)
# ANTIWORD_PATH=antiword
# ANTIWORDHOME=/usr/share/antiword
# POPPLER_BIN=

# ─── PDF OCR Agent ───────────────────────────
PDF_EXTRACTOR_MODE=mistral-script-strict
MISTRAL_PAGEWISE_CORRECTION_ENABLED=true
PDF_OCR_AGENT_ENABLED=true
PDF_OCR_AGENT_TIMEOUT_MS=600000
PDF_OCR_AGENT_PAGES=all
PDF_OCR_AGENT_CLASSIFY_ENABLED=true
PDF_OCR_AGENT_ENHANCE_ENABLED=true
PDF_OCR_ENABLE_VISION_PROOFREAD=false
OPEN_PDF_AGENT_VERIFY_FOOTPRINT=false
OPEN_PDF_AGENT_ENABLE_MCP_STAGE=true

# ─── PDF Vision Models ──────────────────────
# PDF_VISION_COMPARE_MODEL=qwen3-vl-plus-2025-12-19
# PDF_VISION_JUDGE_MODEL=llama-4-scout-17b-16e-instruct
# PDF_VISION_PROOFREAD_MODEL=gemini-2.5-flash
# PDF_VISION_COMPARE_TIMEOUT_MS=180000
# PDF_VISION_JUDGE_TIMEOUT_MS=180000
# PDF_VISION_PROOFREAD_TIMEOUT_MS=180000
# PDF_VISION_RENDER_DPI=300

# ─── Mistral OCR Tuning ─────────────────────
MISTRAL_HTTP_TIMEOUT_MS=120000
MISTRAL_HTTP_MAX_RETRIES=2
MISTRAL_HTTP_RETRY_BASE_MS=500
MISTRAL_BATCH_TIMEOUT_SEC=300
MISTRAL_BATCH_POLL_INTERVAL_SEC=3

# ─── RAG — Qdrant Vector Store ──────────────
# QDRANT_URL=
# QDRANT_API_KEY=

# ─── Neon Disaster Recovery (optional) ──────
# NEON_API_KEY=
# NEON_PROJECT_ID=
# DR_RTO_MINUTES=60
# DR_RPO_MINUTES=15

# ─── Cost Monitoring (optional) ─────────────
# GEMINI_DAILY_COST_LIMIT=10.0
# GEMINI_MONTHLY_BUDGET=300.0

# ─── Email Notifications (optional) ─────────
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@your-domain.com
# ALERT_EMAIL_RECIPIENTS=admin@your-domain.com

# ─── Slack Notifications (optional) ─────────
# SLACK_WEBHOOK_URL=
# SLACK_BOT_TOKEN=

# ─── Vite Legacy (editor sub-app) ───────────
VITE_FILE_IMPORT_BACKEND_URL=http://127.0.0.1:8787/api/file-extract
VITE_AGENT_REVIEW_FAIL_OPEN=true

# ─── Logging ─────────────────────────────────
LOG_LEVEL=info

# ─── Build ───────────────────────────────────
ANALYZE=false
SKIP_ENV_VALIDATION=false
