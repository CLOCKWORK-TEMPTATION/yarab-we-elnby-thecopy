{
  "name": "screenplay-editor",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.28.0",
  "type": "module",
  "description": "محرر سيناريو عربي مبني على Tiptap v3",
  "scripts": {
    "start": "pnpm run start:preflight && pnpm run dev",
    "start:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-preflight.ps1",
    "dev:app": "next dev",
    "dev": "concurrently --kill-others-on-fail -n app,backend -c cyan,green \"pnpm run dev:app\" \"pnpm run file-import:server\"",
    "dev:full": "pnpm run dev",
    "build": "next build",
    "preview": "next start",
    "test": "vitest run --coverage --exclude tests/e2e/**",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run --config vitest.pipeline.config.ts",
    "test:integration:critical": "vitest run --config vitest.pipeline.config.ts tests/integration/server/critical-routes.integration.test.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:audit": "playwright test --config playwright.config.ts tests/e2e/avan-titre-comprehensive-audit.e2e.test.ts",
    "test:e2e:release-gate": "playwright test --config playwright.release.config.ts tests/e2e/avan-titre-comprehensive-audit.e2e.test.ts",
    "test:release:night": "pnpm run test:integration:critical && pnpm run test:e2e:release-gate",
    "test:harness": "vitest run tests/harness",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "agent:setup": "tsx scripts/clean-workspace.ts",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "file-import:server": "node server/file-import-server.mjs",
    "build-antiword:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-antiword-windows.ps1",
    "build-antiword:linux": "powershell -ExecutionPolicy Bypass -File scripts/build-antiword-linux.ps1",
    "build-antiword": "powershell -ExecutionPolicy Bypass -File scripts/build-antiword.ps1",
    "smoke:extract": "powershell -ExecutionPolicy Bypass -File scripts/smoke-extract.ps1",
    "test:integration:watch": "vitest --config vitest.pipeline.config.ts",
    "test:e2e:ui": "playwright test --ui --config playwright.config.ts",
    "test:all": "pnpm run test:integration && pnpm run test:e2e",
    "test:coverage": "vitest run --config vitest.pipeline.config.ts --coverage",
    "pretest:all": "node -e \"require('fs').mkdirSync('test-results',{recursive:true})\"",
    "ocr:start": "tsx src/ocr-arabic-pdf-to-txt-pipeline/agent.ts",
    "ocr:start:batch": "tsx src/ocr-arabic-pdf-to-txt-pipeline/batch.ts",
    "ocr:dev": "tsx watch src/ocr-arabic-pdf-to-txt-pipeline/agent.ts",
    "ocr:typecheck": "tsc --project src/ocr-arabic-pdf-to-txt-pipeline/mcp-server/tsconfig.json --noEmit",
    "ocr:build": "tsc --project src/ocr-arabic-pdf-to-txt-pipeline/mcp-server/tsconfig.json",
    "ocr:build:mcp": "cd src/ocr-arabic-pdf-to-txt-pipeline/mcp-server && npm run build",
    "rag:index": "tsx scripts/rag-index.ts",
    "rag:ask": "tsx scripts/rag-query.ts",
    "rag:stats": "tsx scripts/rag-stats.ts",
    "rag:smoke": "tsx scripts/rag-smoke-test.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/mcp": "^1.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@google/genai": "^1.43.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/anthropic": "^1.3.22",
    "@langchain/core": "^1.1.31",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/openai": "^1.2.12",
    "@mistralai/mistralai": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@tiptap-pro/extension-pages": "1.0.0-alpha.17-rc.9",
    "@tiptap/core": "^3.0.0",
    "@tiptap/extension-bold": "^3.0.0",
    "@tiptap/extension-bubble-menu": "^3.20.0",
    "@tiptap/extension-document": "^3.0.0",
    "@tiptap/extension-italic": "^3.0.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-text": "^3.0.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-underline": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "ai": "^6.0.0",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "docx": "^9.5.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "fast-xml-parser": "^5.4.2",
    "iconv-lite": "^0.7.2",
    "jspdf": "^4.2.0",
    "langchain": "^1.2.30",
    "lucide-react": "^0.474.0",
    "mammoth": "^1.11.0",
    "motion": "^12.34.2",
    "next": "^15.3.3",
    "openai": "^6.25.0",
    "pdfjs-dist": "^5.4.624",
    "pino": "^9.14.0",
    "puppeteer": "^24.37.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.33.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "winax": "^3.6.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "15.5.12",
    "@playwright/test": "^1.56.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "langchain-mcp": "^2.0.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "winax"
    ]
  }
}
