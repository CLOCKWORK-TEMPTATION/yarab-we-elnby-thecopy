{
  "docsDir": "docs/auto",
  "language": "ar",
  "extensions": [
    ".ts",
    ".tsx",
    ".js",
    ".jsx"
  ],
  "excludeDirs": [
    ".git",
    "node_modules",
    "dist",
    "build",
    ".next",
    "coverage",
    ".turbo",
    "out",
    "__pycache__"
  ],
  "excludeFiles": [
    "*.test.ts",
    "*.spec.ts",
    "*.d.ts",
    "*.min.js"
  ],
  "debounceMs": 1500,
  "maxConcurrentRequests": 3,
  "geminiModel": "gemini-3.1-pro-preview",
  "maxTokens": 4096,
  "dbPath": ".doc-watcher.db"
}